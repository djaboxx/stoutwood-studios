# Brand Manager — credentials template
# Copy to .env and fill in. NEVER commit .env.

# Gemini (free tier available at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Google Cloud (for Imagen, Veo, Lyria)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1

# Gmail API (for send_email.py)
# Generate via: gh auth login + scripts/setup_gmail_oauth.py
# Stored in credentials_gmail.json + token_gmail.json (both gitignored)

# LinkedIn API (for publish_social.py)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Instagram Graph API (for publish_social.py)
META_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=

# YouTube Data API (for publish_social.py)
YOUTUBE_CLIENT_SECRETS=credentials/youtube_client_secret.json
